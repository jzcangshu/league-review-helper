# Real review materials: keep these out of public repositories.
# The repository uses a top-level allow-list so accidental school folders are ignored by default.
/*
!/.gitattributes
!/.gitignore
!/LICENSE
!/README.md
!/start-review.cmd
!/start-review.ps1
!/注意事项.txt
!/codex-skills/
!/examples/
!/review-web/
!/审核结果/

审核结果/*
!审核结果/示例中学/
!审核结果/示例中学/**

*.pdf
!examples/示例中学/入团申请资料/*.pdf
examples/**/入团申请资料/*.txt

*.xlsx
!examples/示例中学/示例中学团员名单.xlsx

# Local runtime files
review-web/sources.json
!review-web/sources.json
review-web/sources.local.json
review-web/*.log
review-web/review-web-port.txt
review-web/.ocr-cache/
review-web/.ocr-python/
review-web/.ocr-models/

# Python / Node caches
__pycache__/
*.py[cod]
node_modules/

# OS/editor files
.DS_Store
Thumbs.db
